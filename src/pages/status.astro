    metaTitle: "Status · Project Xiomn",
    eyebrow: "STATUS",
    title: "Status servis awam.",
    intro: "Hanya servis awam dipaparkan. Development tools, 3X-UI dan semakan node berada dalam pusat sistem berpassword.",
    online: "Online",
    protected: "Dilindungi kata laluan",
    botOnline: "Online · Terus ditambah baik",
    siteText: "Homepage, pintu masuk projek dan pusat dokumentasi Project Xiomn.",
