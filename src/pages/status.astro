---

<BaseLayout title="状态 · Project Xiomn" description="Project Xiomn 服务状态页。" active="status" translations={translations}>
  <section class="hero">
    <p class="kicker" data-i18n="eyebrow">{translations.zh.eyebrow}</p>
    <h1 class="hero-title" data-i18n="title">{translations.zh.title}</h1>
    <p class="lead" data-i18n="intro">{translations.zh.intro}</p>
  </section>

  <section class="section">
    <div class="status-list">
      {services.map((service) => (
        <article class="status-item">
          <div class="status-name">
            <span class={`dot ${service.level}`}></span>
            {service.name}
          </div>
          <div class="status-badge" data-i18n={service.badge}>{translations.zh[service.badge]}</div>
          <p data-i18n={service.text}>{translations.zh[service.text]}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
