const services = [
  {
    name: "xiomn.com",
    badge: "online",
    text: "siteText",
    level: "online",
    href: "/",
  },
  {
    name: "Project Xiomn 文档",
    badge: "online",
    text: "docsText",
    level: "online",
    href: "/docs",
  },
  {
    name: "Telegram AI Bot",
    badge: "botOnline",
    text: "botText",
    level: "online",
    href: "https://bot.xiomn.com/status",
    external: true,
  },
  {
    name: "系统管理中心",
    badge: "protected",
    text: "systemText",
    level: "progress",
    href: "/system",
  },
];
---

<BaseLayout title="状态 · Project Xiomn" description="Project Xiomn 公开服务状态。" active="status" translations={translations}>
  <section class="hero">
    <p class="kicker" data-i18n="eyebrow">{translations.zh.eyebrow}</p>
    <h1 class="hero-title" data-i18n="title">{translations.zh.title}</h1>
    <p class="lead" data-i18n="intro">{translations.zh.intro}</p>
  </section>

  <section class="section">
    <div class="status-list">
      {services.map((service) => (
        <article class="status-item">
          <div class="status-name">
            <span class={`dot ${service.level}`}></span>
            {service.name}
          </div>
          <div class="status-badge" data-i18n={service.badge}>{translations.zh[service.badge]}</div>
          <p data-i18n={service.text}>{translations.zh[service.text]}</p>
          <div class="actions" style="grid-column: 1 / -1; margin-top: 8px;">
            <a
              class="btn"
              href={service.href}
              target={service.external ? "_blank" : undefined}
              rel={service.external ? "noreferrer" : undefined}
              data-i18n="open"
            >
              {translations.zh.open}
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
