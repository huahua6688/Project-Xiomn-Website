---
const services = [
  {
    name: "xiomn.com",
    status: "在线",
    level: "online",
    description: "Project Xiomn 官网已通过 Nginx 和 HTTPS 正常运行。",
  },
  {
    name: "code.xiomn.com",
    status: "在线",
    level: "online",
    description: "网页版 VS Code 开发环境已部署，可用于远程修改项目代码。",
  },
  {
    name: "GitHub",
    status: "已连接",
    level: "online",
    description: "项目代码已通过 SSH 推送到 GitHub 仓库。",
  },
  {
    name: "自动部署",
    status: "已配置",
    level: "progress",
    description: "服务器会检查 GitHub 更新，并可通过 deploy.sh 手动部署。",
  },
  {
    name: "Telegram AI Bot",
    status: "开发中",
    level: "progress",
    description: "后续会继续整理 Gemini、Gemini Live、按钮交互和 Zeabur 部署方案。",
  },
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>状态 · Project Xiomn</title>
    <meta name="description" content="Project Xiomn 服务状态页。" />
  </head>

  <body>
    <main class="page">
      <nav>
        <a href="/">首页</a>
        <a href="/projects">项目</a>
        <a href="/docs">文档</a>
      </nav>

      <section class="hero">
        <p>STATUS</p>
        <h1>系统状态。</h1>
        <span>
          这里记录 Project Xiomn 当前已经上线、正在开发和后续准备接入的服务。
        </span>
      </section>

      <section class="list">
        {services.map((service) => (
          <article class="item">
            <div>
              <span class={`dot ${service.level}`}></span>
              <strong>{service.name}</strong>
            </div>
            <b>{service.status}</b>
            <p>{service.description}</p>
          </article>
        ))}
      </section>
    </main>

    <style>
      :root {
        color-scheme: dark;
        --bg: #05060a;
        --text: rgba(255, 255, 255, 0.94);
        --muted: rgba(255, 255, 255, 0.64);
        --line: rgba(255, 255, 255, 0.14);
        --card: rgba(255, 255, 255, 0.08);
        --cyan: #77ffe1;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(119, 255, 225, 0.16), transparent 34rem),
          radial-gradient(circle at bottom right, rgba(98, 168, 255, 0.18), transparent 32rem),
          var(--bg);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        width: min(1000px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0 80px;
      }

      nav {
        display: flex;
        gap: 20px;
        margin-bottom: 80px;
      }

      nav a {
        color: var(--muted);
      }

      nav a:hover {
        color: var(--text);
      }

      .hero {
        margin-bottom: 48px;
      }

      .hero p {
        color: var(--cyan);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.18em;
      }

      h1 {
        max-width: 900px;
        margin: 0;
        font-size: clamp(54px, 9vw, 112px);
        line-height: 0.92;
        letter-spacing: -0.08em;
      }

      .hero span {
        display: block;
        max-width: 720px;
        margin-top: 26px;
        color: var(--muted);
        font-size: 20px;
        line-height: 1.7;
      }

      .list {
        display: grid;
        gap: 14px;
      }

      .item {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px 22px;
        padding: 24px;
        border: 1px solid var(--line);
        border-radius: 26px;
        background: var(--card);
        backdrop-filter: blur(20px);
      }

      .item p {
        grid-column: 1 / -1;
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
      }

      .dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        margin-right: 10px;
        border-radius: 50%;
      }

      .online {
        background: #70ffb5;
        box-shadow: 0 0 18px rgba(112, 255, 181, 0.65);
      }

      .progress {
        background: #ffd36e;
        box-shadow: 0 0 18px rgba(255, 211, 110, 0.65);
      }

      b {
        color: var(--cyan);
      }

      @media (max-width: 700px) {
        .item {
          grid-template-columns: 1fr;
        }

        nav {
          flex-wrap: wrap;
        }
      }
    </style>
  </body>
</html>
