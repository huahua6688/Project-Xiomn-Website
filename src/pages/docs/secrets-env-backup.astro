---
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = [
  ["Project-Xiomn-Website", "通常不需要敏感环境变量，主要依赖 GitHub 和 Zeabur 构建。"],
  ["Telegram-AI-Bot-Pro", "需要 BOT_TOKEN、Gemini Key、模型配置、数据库路径、后台密码等。"],
  ["code-server", "需要 PASSWORD，建议配置 Volume 保存工作目录。"],
];

const rules = [
  "真实 API Key 不要提交到 GitHub。",
  "Zeabur 环境变量要单独备份一份，但不要公开。",
  "每个项目都要写清楚变量名、用途、是否必填。",
  "换 Zeabur 或换服务器时，先恢复环境变量，再部署项目。",
  "如果某个变量缺失会导致启动失败，必须在 README 或文档里写清楚。",
];

const botEnvTemplate = `# Telegram-AI-Bot-Pro 环境变量模板
# 注意：这里只记录变量名，不要把真实密钥提交到 GitHub

BOT_TOKEN=
AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash
AI_API_KEY=
AI_BASE_URL=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=

GEMINI_LIVE_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.5-flash-preview-native-audio-dialog
GEMINI_LIVE_BASE_URL=

DATABASE_FILE=/data/database.sqlite
PASSWORD=
PORT=8080`;

const codeServerEnv = `# code-server
PASSWORD=你的强密码

# 推荐端口
PORT=8080

# 推荐卷挂载路径
/home/coder/project`;
---

<BaseLayout
  title="环境变量备份 · Project Xiomn"
  description="记录 Project Xiomn 各项目需要备份的环境变量。"
  active="docs"
>
  <section class="hero">
    <p class="kicker">SECRETS</p>
    <h1 class="hero-title">环境变量备份。</h1>
    <p class="lead">
      这页只记录变量名、用途和模板。真实 API Key、Token、密码不要提交到 GitHub，也不要写进公开网页。
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="kicker">PROJECTS</p>
        <h2 class="section-title">当前项目变量需求</h2>
      </div>
    </div>

    <div class="grid two">
      {projects.map(([title, text]) => (
        <article class="card">
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="kicker">BOT ENV</p>
        <h2 class="section-title">Telegram Bot 环境变量模板</h2>
      </div>
    </div>

    <article class="panel prompt-panel">
      <pre class="prompt-code"><code>{botEnvTemplate}</code></pre>
    </article>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="kicker">CODE SERVER</p>
        <h2 class="section-title">code-server 环境变量</h2>
      </div>
    </div>

    <article class="panel prompt-panel">
      <pre class="prompt-code"><code>{codeServerEnv}</code></pre>
    </article>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="kicker">RULES</p>
        <h2 class="section-title">备份规则</h2>
      </div>
    </div>

    <div class="timeline">
      {rules.map((item, index) => (
        <div class="timeline-item">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <p>{item}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
