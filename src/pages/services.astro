---
import BaseLayout from "../layouts/BaseLayout.astro";

const translations = {
  zh: {
    metaTitle: "服务 · Project Xiomn",
    eyebrow: "SERVICES",
    title: "统一服务入口。",
    intro: "公开服务放在这里；开发环境、服务器面板和节点信息统一放入密码保护的系统中心。",
    botTitle: "Telegram AI Bot",
    botText: "查看机器人项目介绍、已实现能力和后续路线。",
