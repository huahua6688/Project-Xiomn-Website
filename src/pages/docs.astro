---
import BaseLayout from "../layouts/BaseLayout.astro";

const primaryDocs = [
  ["服务与域名来源", "/docs/services-and-domains", "记录每个网页、域名、面板和节点是怎么来的，以及打不开时先检查什么。", "MAP"],
  ["总运维手册", "/docs/operations-playbook", "服务器、Zeabur、域名、备份、部署和排错的总入口。", "HUB"],
  ["当前基础设施", "/docs/current-infrastructure", "记录网站、code-server、3X-UI、节点和 Telegram Bot 的关系。", "LIVE"],
  ["域名与入口规则", "/docs/domain-routing", "记录 xiomn.com、code、panel、node、bot 应该绑定到哪里。", "ROUTING"],
  ["Zeabur 迁移恢复", "/docs/zeabur-migration", "以后换服务器、换 Zeabur、换平台时按这个恢复。", "MIGRATION"],
];

const deployDocs = [
  ["服务器部署记录", "/docs/server-deployment", "早期 Nginx、HTTPS、Astro、GitHub、deploy.sh 的部署记录。"],
  ["Zeabur 部署排错", "/docs/zeabur-troubleshooting", "BackOff、端口、环境变量、pdf-parse、启动失败排查。"],
  ["Telegram Bot Zeabur 部署", "/docs/telegram-bot-zeabur-deploy", "Telegram-AI-Bot-Pro 在 Zeabur 的部署顺序、变量和排错点。"],
];

const botDocs = [
  ["Telegram AI Bot", "/docs/telegram-ai-bot", "Bot 功能、环境变量、已知错误、下一步计划。"],
  ["Gemini 与 Gemini Live", "/docs/gemini-live", "普通 Gemini、Gemini Live、语音、Provider 架构设计。"],
  ["Copilot 重构提示词", "/docs/copilot-refactor-prompt", "可直接给 GitHub Copilot Agent 的完整重构要求。"],
];

const backupDocs = [
  ["环境变量备份", "/docs/secrets-env-backup", "记录变量名、用途和模板，真实 Key 不进 GitHub。"],
  ["数据卷备份", "/docs/volume-backup", "记录 Volume、SQLite、上传文件、code-server 工作目录备份规则。"],
];

const routeMap = [
  ["xiomn.com", "Project-Xiomn-Website", "个人主页 + 文档 + /system"],
  ["code.xiomn.com", "code-server / Coder", "浏览器开发环境"],
  ["panel.xiomn.com:2053", "3X-UI", "节点管理面板"],
  ["node.xiomn.com", "Xray / Reality", "节点域名，不是网页"],
  ["bot.xiomn.com", "Telegram-AI-Bot-Pro", "Bot 后端；/status 给人查看"],
];

const quickCommands = [
  ["检查 K3s", "sudo systemctl status k3s --no-pager"],
  ["看全部 Pod", "sudo k3s kubectl get pods -A"],
  ["看异常 Pod", "sudo k3s kubectl get pods -A | grep -v Running"],
  ["检查 3X-UI", "sudo x-ui status"],
  ["检查节点 DNS", "getent hosts node.xiomn.com"],
];

const rules = [
  "同一个域名只绑定一个服务，xiomn.com 不再同时绑定旧 Portal。",
  "官网更新走 GitHub → Zeabur，不再走 /var/www/html。",
  "真实 API Key、密码、Bot Token 和节点密钥不提交 GitHub。",
  "有数据库、文件、用户设置的服务必须配置 Volume。",
  "node.xiomn.com 是客户端节点地址，不用浏览器网页是否打开来判断。",
  "bot.xiomn.com/app 是 Telegram Mini App，必须从 Telegram 内打开。",
];

const architecture = `当前结构：

Project-Xiomn-Website
├─ xiomn.com
├─ /services
├─ /docs
├─ /status
└─ /system（密码保护）

独立服务
├─ code.xiomn.com       code-server / Coder
├─ panel.xiomn.com:2053 3X-UI
├─ node.xiomn.com       Xray / Reality 节点
└─ bot.xiomn.com        Telegram AI Bot`;

const updateFlow = `以后官网更新流程：

npm run build
node --test
git add .
git commit -m "update website"
git push

然后等待 Zeabur 自动重新部署。`;
---

<BaseLayout
  title="文档中心 · Project Xiomn"
  description="Project Xiomn 的文档中心、运维手册、域名与服务来源、部署规则和备份规则。"
  active="docs"
>
  <section class="hero">
    <p class="kicker">DOCUMENTATION CENTER</p>
    <h1 class="hero-title">Project Xiomn 文档中心。</h1>
    <p class="lead">
      服务器、Zeabur、域名、code-server、3X-UI、节点、Bot、备份、迁移和排错都从这里进入。
    </p>
    <div class="hero-actions">
      <a class="primary-action" href="/docs/services-and-domains">查看服务来源记录</a>
      <a class="secondary-action" href="/docs/operations-playbook">打开总运维手册</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div><p class="kicker">CURRENT ARCHITECTURE</p><h2 class="section-title">当前结构</h2></div>
      <p class="section-desc">先区分网页、程序接口、管理面板和节点域名，再进行排错。</p>
    </div>
    <article class="panel prompt-panel"><pre class="prompt-code"><code>{architecture}</code></pre></article>
  </section>

  <section class="section">
    <div class="section-head"><div><p class="kicker">IMPORTANT</p><h2 class="section-title">最重要的入口</h2></div></div>
    <div class="doc-dashboard">
      {primaryDocs.map(([title, href, text, tag]) => (
        <a class="doc-dashboard-card" href={href}><span>{tag}</span><h3>{title}</h3><p>{text}</p></a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><p class="kicker">ROUTES</p><h2 class="section-title">域名与用途</h2></div></div>
    <div class="route-table">
      {routeMap.map(([domain, service, role]) => (
        <div class="route-row"><strong>{domain}</strong><span>{service}</span><em>{role}</em></div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><p class="kicker">DEPLOYMENT</p><h2 class="section-title">部署与排错</h2></div></div>
    <div class="grid three">
      {deployDocs.map(([title, href, text]) => (
        <article class="card"><h3>{title}</h3><p>{text}</p><a href={href}>打开 →</a></article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><p class="kicker">BOT DEVELOPMENT</p><h2 class="section-title">Telegram AI Bot 开发</h2></div></div>
    <div class="grid three">
      {botDocs.map(([title, href, text]) => (
        <article class="card"><h3>{title}</h3><p>{text}</p><a href={href}>打开 →</a></article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><p class="kicker">BACKUP</p><h2 class="section-title">备份与迁移</h2></div></div>
    <div class="grid two">
      {backupDocs.map(([title, href, text]) => (
        <article class="card"><h3>{title}</h3><p>{text}</p><a href={href}>打开 →</a></article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><p class="kicker">COMMANDS</p><h2 class="section-title">常用检查命令</h2></div></div>
    <div class="command-grid">
      {quickCommands.map(([title, command]) => (
        <article class="command-card"><h3>{title}</h3><pre><code>{command}</code></pre></article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><p class="kicker">UPDATE FLOW</p><h2 class="section-title">官网更新流程</h2></div></div>
    <article class="panel prompt-panel"><pre class="prompt-code"><code>{updateFlow}</code></pre></article>
  </section>

  <section class="section">
    <div class="section-head"><div><p class="kicker">RULES</p><h2 class="section-title">必须遵守的规则</h2></div></div>
    <div class="timeline">
      {rules.map((item, index) => (
        <div class="timeline-item"><span>{String(index + 1).padStart(2, "0")}</span><p>{item}</p></div>
      ))}
    </div>
  </section>
</BaseLayout>
