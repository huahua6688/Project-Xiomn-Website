---
const docs = [
  {
    title: "Project Xiomn 入门",
    description: "了解 Project Xiomn 的结构、服务器、域名、GitHub 和部署流程。",
    status: "已开始",
  },
  {
    title: "Telegram AI Bot 部署",
    description: "记录 Telegram AI Bot 在 Zeabur / VPS 上的部署方式、环境变量和常见错误。",
    status: "整理中",
  },
  {
    title: "Gemini 与 Gemini Live",
    description: "整理普通 Gemini、Gemini Live、语音对话、识图和文件解析的接入方案。",
    status: "计划中",
  },
  {
    title: "服务器与自动部署",
    description: "记录 Nginx、HTTPS、Astro、GitHub、自动部署脚本和常用维护命令。",
    status: "已开始",
  },
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>文档 · Project Xiomn</title>
    <meta name="description" content="Project Xiomn 文档中心。" />
  </head>

  <body>
    <main class="page">
      <nav>
        <a href="/">← 返回 Xiomn 首页</a>
        <a href="/projects">项目</a>
      </nav>

      <section class="hero">
        <p>DOCS</p>
        <h1>文档中心。</h1>
        <span>
          这里会记录 Project Xiomn 的部署过程、AI Bot 配置、Gemini 接入、服务器维护和自动化流程。
        </span>
      </section>

      <section class="grid">
        {docs.map((item) => (
          <article class="card">
            <div>
              <strong>{item.status}</strong>
              <h2>{item.title}</h2>
            </div>
            <p>{item.description}</p>
          </article>
        ))}
      </section>
    </main>

    <style>
      :root {
        color-scheme: dark;
        --bg: #05060a;
        --text: rgba(255, 255, 255, 0.94);
        --muted: rgba(255, 255, 255, 0.64);
        --line: rgba(255, 255, 255, 0.14);
        --card: rgba(255, 255, 255, 0.08);
        --cyan: #77ffe1;
        --blue: #62a8ff;
        --purple: #b58cff;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(98, 168, 255, 0.22), transparent 34rem),
          radial-gradient(circle at bottom right, rgba(181, 140, 255, 0.16), transparent 32rem),
          var(--bg);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        width: min(1100px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0 80px;
      }

      nav {
        display: flex;
        gap: 20px;
        margin-bottom: 80px;
      }

      nav a {
        color: var(--muted);
      }

      nav a:hover {
        color: var(--text);
      }

      .hero {
        margin-bottom: 48px;
      }

      .hero p {
        color: var(--cyan);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.18em;
      }

      h1 {
        max-width: 900px;
        margin: 0;
        font-size: clamp(54px, 9vw, 112px);
        line-height: 0.92;
        letter-spacing: -0.08em;
      }

      .hero span {
        display: block;
        max-width: 760px;
        margin-top: 26px;
        color: var(--muted);
        font-size: 20px;
        line-height: 1.7;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
      }

      .card {
        min-height: 230px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 26px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: var(--card);
        backdrop-filter: blur(20px);
      }

      strong {
        color: var(--cyan);
        font-size: 13px;
      }

      h2 {
        margin: 16px 0 0;
        font-size: 30px;
        letter-spacing: -0.045em;
      }

      .card p {
        color: var(--muted);
        line-height: 1.7;
      }

      @media (max-width: 860px) {
        .grid {
          grid-template-columns: 1fr;
        }

        nav {
          flex-wrap: wrap;
        }
      }
    </style>
  </body>
</html>
