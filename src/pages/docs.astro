---

<BaseLayout title="文档 · Project Xiomn" description="Project Xiomn 文档中心。" active="docs" translations={translations}>
  <section class="hero">
    <p class="kicker" data-i18n="eyebrow">{translations.zh.eyebrow}</p>
    <h1 class="hero-title" data-i18n="title">{translations.zh.title}</h1>
    <p class="lead" data-i18n="intro">{translations.zh.intro}</p>
  </section>

  <section class="section">
    <div class="grid two">
      {docs.map((doc) => (
        <article class="card">
          <p class="status-badge" data-i18n={doc.status}>{translations.zh[doc.status]}</p>
          <h2 data-i18n={doc.title}>{translations.zh[doc.title]}</h2>
          <p data-i18n={doc.text}>{translations.zh[doc.text]}</p>
          {doc.href && (
            <div class="tags">
              <a href={doc.href}>
                <span data-i18n={doc.link}>{translations.zh[doc.link]}</span>
              </a>
            </div>
          )}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
