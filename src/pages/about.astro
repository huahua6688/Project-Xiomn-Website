const stack = ["Astro", "Nginx", "Ubuntu", "GitHub", "Docker", "Telegram Bot", "Gemini", "Cloudflare"];
---

<BaseLayout title="关于 · Project Xiomn" description="关于 Project Xiomn。" active="about" translations={translations}>
  <section class="hero">
    <p class="kicker" data-i18n="eyebrow">{translations.zh.eyebrow}</p>
    <h1 class="hero-title" data-i18n="title">{translations.zh.title}</h1>
    <p class="lead" data-i18n="intro">{translations.zh.intro}</p>
  </section>

  <section class="section">
    <div class="grid two">
      <article class="panel">
        <p class="kicker" data-i18n="whyLabel">{translations.zh.whyLabel}</p>
        <h2 class="section-title" data-i18n="whyTitle">{translations.zh.whyTitle}</h2>
        <p data-i18n="whyText">{translations.zh.whyText}</p>
      </article>

      <article class="panel">
        <p class="kicker" data-i18n="focusLabel">{translations.zh.focusLabel}</p>
        <h2 class="section-title" data-i18n="focusTitle">{translations.zh.focusTitle}</h2>
        <p data-i18n="focusText">{translations.zh.focusText}</p>
      </article>
    </div>
  </section>

  <section class="section">
    <p class="kicker" data-i18n="stackLabel">{translations.zh.stackLabel}</p>
    <h2 class="section-title" data-i18n="stackTitle">{translations.zh.stackTitle}</h2>
    <div class="tags">
      {stack.map((item) => <span>{item}</span>)}
    </div>
  </section>
</BaseLayout>
