---
const year = new Date().getFullYear();
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Project Xiomn</title>
    <meta
      name="description"
      content="Project Xiomn is a personal AI, Telegram bot, cloud and open-source lab."
    />
  </head>

  <body>
    <main class="page">
      <nav class="nav">
        <a class="brand" href="/">
          <span class="brand-mark">X</span>
          <span>Project Xiomn</span>
        </a>

        <div class="nav-links">
          <a href="/projects" data-i18n="navProjects">项目</a>
          <a href="/docs" data-i18n="navDocs">文档</a>
          <a href="/about" data-i18n="navAbout">关于</a>
          <a href="/status" data-i18n="navStatus">状态</a>
        </div>

        <div class="lang">
          <button data-lang="zh" class="active">中</button>
          <button data-lang="en">EN</button>
          <button data-lang="ja">日</button>
          <button data-lang="km">ខ្មែរ</button>
          <button data-lang="ms">MS</button>
        </div>
      </nav>

      <section class="hero">
        <p class="eyebrow" data-i18n="eyebrow">AI · Telegram · Cloud · Open Source</p>
        <h1>
          <span data-i18n="heroTitleA">Build once.</span>
          <span class="gradient" data-i18n="heroTitleB">Grow forever.</span>
        </h1>
        <p class="hero-text" data-i18n="heroText">
          Project Xiomn 是一个个人 AI 实验室，用来构建 Telegram AI Bot、云端服务、自动化工具和开源项目。
        </p>

        <div class="actions">
          <a class="btn primary" href="#projects" data-i18n="primaryBtn">查看项目</a>
          <a class="btn ghost" href="https://github.com/huahua6688" target="_blank" rel="noreferrer">
            GitHub
          </a>
        </div>

        <div class="hero-panel">
          <div class="terminal">
            <div class="dots">
              <span></span><span></span><span></span>
            </div>
            <pre><code>project@xiomn:~$ npm run build
✓ Astro generated production site
✓ Deployed to xiomn.com

status: online
mode: build in public</code></pre>
          </div>
        </div>
      </section>

      <section id="projects" class="section">
        <div class="section-head">
          <p class="eyebrow" data-i18n="projectsEyebrow">PROJECTS</p>
          <h2 data-i18n="projectsTitle">正在构建的东西</h2>
        </div>

        <div class="grid">
          <article class="card">
            <div class="icon">🤖</div>
            <h3 data-i18n="botTitle">Telegram AI Bot</h3>
            <p data-i18n="botText">
              支持普通 Gemini、Gemini Live、语音、识图、文件解析和按钮交互的万能 Telegram AI Bot。
            </p>
          </article>

          <article class="card">
            <div class="icon">☁️</div>
            <h3 data-i18n="cloudTitle">Xiomn Cloud</h3>
            <p data-i18n="cloudText">
              基于 VPS、Nginx、Docker、HTTPS 和自动部署组成的个人云端实验环境。
            </p>
          </article>

          <article class="card">
            <div class="icon">🧩</div>
            <h3 data-i18n="ossTitle">Open Source Lab</h3>
            <p data-i18n="ossText">
              用 GitHub 管理版本，把每一次修改都沉淀成可复用、可部署、可公开展示的项目。
            </p>
          </article>
        </div>
      </section>

      <section id="roadmap" class="section split">
        <div>
          <p class="eyebrow" data-i18n="roadmapEyebrow">ROADMAP</p>
          <h2 data-i18n="roadmapTitle">下一步计划</h2>
          <p class="muted" data-i18n="roadmapText">
            Project Xiomn 会从一个个人主页，逐步发展成 AI 工具、Bot、文档和服务的统一入口。
          </p>
        </div>

        <div class="steps">
          <div class="step">
            <span>01</span>
            <p data-i18n="stepOne">完成官网首页和多语言切换</p>
          </div>
          <div class="step">
            <span>02</span>
            <p data-i18n="stepTwo">接入 GitHub 自动部署流程</p>
          </div>
          <div class="step">
            <span>03</span>
            <p data-i18n="stepThree">上线 Telegram AI Bot 展示页</p>
          </div>
          <div class="step">
            <span>04</span>
            <p data-i18n="stepFour">发布文档、博客和服务状态页</p>
          </div>
        </div>
      </section>

      <section id="status" class="section status">
        <p class="eyebrow" data-i18n="statusEyebrow">STATUS</p>
        <h2 data-i18n="statusTitle">系统状态</h2>

        <div class="status-grid">
          <div>
            <span class="dot online"></span>
            <strong>xiomn.com</strong>
            <p data-i18n="statusSite">官网在线</p>
          </div>
          <div>
            <span class="dot online"></span>
            <strong>code.xiomn.com</strong>
            <p data-i18n="statusCode">开发环境在线</p>
          </div>
          <div>
            <span class="dot progress"></span>
            <strong>Telegram AI Bot</strong>
            <p data-i18n="statusBot">开发中</p>
          </div>
        </div>
      </section>

      <footer class="footer">
        <span>© {year} Project Xiomn</span>
        <span data-i18n="footerText">Built with Astro, Nginx and GitHub.</span>
      </footer>
    </main>

