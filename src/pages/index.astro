const cards = [
  { icon: "🤖", title: "botTitle", text: "botText", href: "/telegram-ai-bot" },
  { icon: "☁️", title: "servicesTitle", text: "servicesText", href: "/services" },
  { icon: "📚", title: "docsTitle", text: "docsText", href: "/docs/services-and-domains" },
];

const architecture = [
  ["xiomn.com", "websiteLabel"],
  ["bot.xiomn.com", "botLabel"],
  ["code.xiomn.com", "codeLabel"],
  ["panel.xiomn.com:2053", "panelLabel"],
  ["node.xiomn.com", "nodeLabel"],
  ["xiomn.com/system", "protectedLabel"],
];

const steps = ["stepOne", "stepTwo", "stepThree"];
---

<BaseLayout
  title="Project Xiomn · AI、Telegram 与个人云服务"
  description="Project Xiomn 个人技术主页、Telegram AI Bot、云端服务入口和运维文档中心。"
  active="home"
  translations={translations}
>
  <section class="hero center">
    <p class="kicker" data-i18n="eyebrow">{translations.zh.eyebrow}</p>
    <h1 class="hero-title">
      <span data-i18n="heroTitleA">{translations.zh.heroTitleA}</span>
      <span class="gradient" data-i18n="heroTitleB">{translations.zh.heroTitleB}</span>
    </h1>
    <p class="lead" data-i18n="heroText">{translations.zh.heroText}</p>
    <div class="actions">
      <a class="btn primary" href="/services" data-i18n="primaryBtn">{translations.zh.primaryBtn}</a>
      <a class="btn" href="/docs" data-i18n="secondaryBtn">{translations.zh.secondaryBtn}</a>
      <a class="btn" href="/system" data-i18n="systemBtn">{translations.zh.systemBtn}</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="kicker" data-i18n="overviewEyebrow">{translations.zh.overviewEyebrow}</p>
        <h2 class="section-title" data-i18n="overviewTitle">{translations.zh.overviewTitle}</h2>
      </div>
      <p class="section-desc" data-i18n="overviewDesc">{translations.zh.overviewDesc}</p>
    </div>

    <div class="grid three">
      {cards.map((card) => (
        <article class="card">
          <div class="card-icon">{card.icon}</div>
          <h3 data-i18n={card.title}>{translations.zh[card.title]}</h3>
          <p data-i18n={card.text}>{translations.zh[card.text]}</p>
          <div class="actions">
            <a class="btn" href={card.href} data-i18n="openDetails">{translations.zh.openDetails}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="kicker" data-i18n="architectureEyebrow">{translations.zh.architectureEyebrow}</p>
        <h2 class="section-title" data-i18n="architectureTitle">{translations.zh.architectureTitle}</h2>
      </div>
    </div>

    <div class="route-table">
      {architecture.map(([domain, label]) => (
        <div class="route-row">
          <strong>{domain}</strong>
          <span data-i18n={label}>{translations.zh[label]}</span>
          <em>{domain === "node.xiomn.com" ? "NODE" : domain.includes("/system") ? "PRIVATE" : "ONLINE"}</em>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <p class="kicker" data-i18n="statusEyebrow">{translations.zh.statusEyebrow}</p>
    <h2 class="section-title" data-i18n="statusTitle">{translations.zh.statusTitle}</h2>

    <div class="status-list" style="margin-top: 26px;">
      <article class="status-item">
        <div class="status-name"><span class="dot online"></span>xiomn.com</div>
        <div class="status-badge" data-i18n="websiteOnline">{translations.zh.websiteOnline}</div>
      </article>
      <article class="status-item">
        <div class="status-name"><span class="dot online"></span>Telegram AI Bot</div>
        <div class="status-badge" data-i18n="botOnline">{translations.zh.botOnline}</div>
      </article>
      <article class="status-item">
        <div class="status-name"><span class="dot progress"></span>xiomn.com/system</div>
        <div class="status-badge" data-i18n="systemProtected">{translations.zh.systemProtected}</div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="grid two">
      <div>
        <p class="kicker" data-i18n="roadmapEyebrow">{translations.zh.roadmapEyebrow}</p>
        <h2 class="section-title" data-i18n="roadmapTitle">{translations.zh.roadmapTitle}</h2>
      </div>

      <div class="timeline">
        {steps.map((step, index) => (
          <div class="timeline-item">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <p data-i18n={step}>{translations.zh[step]}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
