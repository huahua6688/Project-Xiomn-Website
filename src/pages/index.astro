const cards = [
  { icon: "🤖", title: "botTitle", text: "botText" },
  { icon: "☁️", title: "cloudTitle", text: "cloudText" },
  { icon: "📚", title: "docsTitle", text: "docsText" },
];

const steps = ["stepOne", "stepTwo", "stepThree"];
---

<BaseLayout title="Project Xiomn" description="Project Xiomn" active="home" translations={translations}>
  <section class="hero center">
    <p class="kicker" data-i18n="eyebrow">{translations.zh.eyebrow}</p>
    <h1 class="hero-title">
      <span data-i18n="heroTitleA">{translations.zh.heroTitleA}</span>
      <span class="gradient" data-i18n="heroTitleB">{translations.zh.heroTitleB}</span>
    </h1>
    <p class="lead" data-i18n="heroText">{translations.zh.heroText}</p>
    <div class="actions">
      <a class="btn primary" href="/projects" data-i18n="primaryBtn">{translations.zh.primaryBtn}</a>
      <a class="btn" href="/docs" data-i18n="secondaryBtn">{translations.zh.secondaryBtn}</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="kicker" data-i18n="projectsEyebrow">{translations.zh.projectsEyebrow}</p>
        <h2 class="section-title" data-i18n="projectsTitle">{translations.zh.projectsTitle}</h2>
      </div>
      <p class="section-desc" data-i18n="projectsDesc">{translations.zh.projectsDesc}</p>
    </div>

    <div class="grid three">
      {cards.map((card) => (
        <article class="card">
          <div class="card-icon">{card.icon}</div>
          <h3 data-i18n={card.title}>{translations.zh[card.title]}</h3>
          <p data-i18n={card.text}>{translations.zh[card.text]}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="grid two">
      <div>
        <p class="kicker" data-i18n="roadmapEyebrow">{translations.zh.roadmapEyebrow}</p>
        <h2 class="section-title" data-i18n="roadmapTitle">{translations.zh.roadmapTitle}</h2>
      </div>

      <div class="timeline">
        {steps.map((step, index) => (
          <div class="timeline-item">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <p data-i18n={step}>{translations.zh[step]}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <p class="kicker" data-i18n="statusEyebrow">{translations.zh.statusEyebrow}</p>
    <h2 class="section-title" data-i18n="statusTitle">{translations.zh.statusTitle}</h2>

    <div class="status-list" style="margin-top: 26px;">
      <article class="status-item">
        <div class="status-name"><span class="dot online"></span>xiomn.com</div>
        <div class="status-badge" data-i18n="siteOnline">{translations.zh.siteOnline}</div>
      </article>
      <article class="status-item">
        <div class="status-name"><span class="dot online"></span>code.xiomn.com</div>
        <div class="status-badge" data-i18n="codeOnline">{translations.zh.codeOnline}</div>
      </article>
      <article class="status-item">
        <div class="status-name"><span class="dot progress"></span>Telegram AI Bot</div>
        <div class="status-badge" data-i18n="botProgress">{translations.zh.botProgress}</div>
      </article>
    </div>
  </section>
</BaseLayout>
