    siteTitle: "Project Xiomn Website",
    siteStatus: "ដំណើរការ",
    siteText: "គេហទំព័រសាធារណៈ ច្រកចូលគម្រោង និងមជ្ឈមណ្ឌលឯកសារនាពេលក្រោយ។",
  },
  ms: {
    metaTitle: "Projek · Project Xiomn",
    eyebrow: "PROJECTS",
    title: "Pusat projek.",
    intro: "Tempat untuk projek yang sedang dibina, dideploy dan dikembangkan di bawah Project Xiomn.",
    botTitle: "Telegram AI Bot",
    botStatus: "Online · Terus ditambah baik",
    botText: "Telegram AI assistant yang sudah dideploy dengan multi-provider routing, fallback automatik, natural-language routing, carian web, pemprosesan URL/imej/suara/fail, memori dan inline actions.",
