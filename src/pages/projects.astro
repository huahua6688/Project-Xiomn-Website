const projects = [
  { title: "botTitle", status: "botStatus", text: "botText", tags: ["Telegram", "Gemini", "Live API", "Bot"] },
  { title: "cloudTitle", status: "cloudStatus", text: "cloudText", tags: ["VPS", "Nginx", "Docker", "HTTPS"] },
  { title: "siteTitle", status: "siteStatus", text: "siteText", tags: ["Astro", "GitHub", "Static Site"] },
];
---

<BaseLayout title="项目 · Project Xiomn" description="Project Xiomn 项目中心。" active="projects" translations={translations}>
  <section class="hero">
    <p class="kicker" data-i18n="eyebrow">{translations.zh.eyebrow}</p>
    <h1 class="hero-title" data-i18n="title">{translations.zh.title}</h1>
    <p class="lead" data-i18n="intro">{translations.zh.intro}</p>
  </section>

  <section class="section">
    <div class="grid three">
      {projects.map((project) => (
        <article class="card">
          <h2 data-i18n={project.title}>{translations.zh[project.title]}</h2>
          <p class="status-badge" data-i18n={project.status}>{translations.zh[project.status]}</p>
          <p data-i18n={project.text}>{translations.zh[project.text]}</p>
          <div class="tags">
            {project.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
