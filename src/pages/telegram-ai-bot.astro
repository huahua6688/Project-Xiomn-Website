---
import BaseLayout from "../layouts/BaseLayout.astro";

const features = [
  "多 AI Provider：Gemini、OpenRouter、Groq 等，并支持用户独立选择",
  "自动故障转移：重试、冷却、模型回退和 Provider 切换",
  "自然语言自动路由：聊天、翻译、搜索、写作和问答",
  "联网搜索与网页读取，可自动处理用户发送的链接",
  "图片理解、语音转文字、文字转语音与 Gemini Live 可选接入",
  "文件解析与总结：PDF / DOCX / XLSX / TXT / Markdown / CSV",
  "Telegram 内联按钮、回复操作条、模型/语言/人格/记忆设置",
  "SQLite 持久化、管理员控制、配额限制与健康检查",
  "Zeabur / VPS / Docker 部署支持",
];

const envs = [
  "BOT_TOKEN",
  "ADMIN_USER_IDS",
  "DEFAULT_AI_PROVIDER",
  "DEFAULT_AI_MODEL",
  "GEMINI_API_KEY",
  "OPENROUTER_API_KEY",
  "GROQ_API_KEY",
  "GEMINI_LIVE_API_KEY",
  "ENABLE_PROVIDER_FALLBACK",
  "DATABASE_FILE",
  "PORT",
];

const nextActions = [
  "优化回答格式与链接展示，默认避免冗长裸链接",
  "继续完善 Gemini Live 音频、TTS 和实时翻译",
  "增强 Provider 状态诊断、额度错误提示和自动恢复",
  "补齐部署文档、环境变量模板和运维说明",
  "持续增加回归测试、线上监控和长期稳定性验证",
];

const translations = {
  zh: {
    metaTitle: "Telegram AI Bot · Project Xiomn",
    eyebrow: "TELEGRAM AI BOT",
    title: "万能 Telegram AI Bot。",
    intro:
      "Telegram-AI-Bot-Pro 已从启动调试阶段进入可用部署与持续迭代阶段。当前版本强调自然语言交互、多 Provider 自动切换、多模态处理、持久化记忆和 Telegram 内联操作。",
    featureTitle: "当前已实现",
    envTitle: "核心环境变量",
    nextTitle: "接下来继续完善",
    statusTitle: "当前状态",
    statusText:
      "Bot 已在 Zeabur 运行。基础对话、自动路由、多 Provider、故障转移、联网搜索、网页读取、图片/语音/文件处理、内联按钮、设置中心、记忆和管理功能已经落地；Gemini Live 实时音频、图片生成和回答格式仍会按配置与额度继续完善。",
    repoLabel: "打开 GitHub 仓库",
  },
  en: {
    metaTitle: "Telegram AI Bot · Project Xiomn",
    eyebrow: "TELEGRAM AI BOT",
    title: "Universal Telegram AI Bot.",
    intro:
      "Telegram-AI-Bot-Pro has moved from startup debugging into a usable deployment and continuous iteration stage. The current version focuses on natural-language interaction, multi-provider fallback, multimodal handling, persistent memory and Telegram inline actions.",
    featureTitle: "Implemented now",
    envTitle: "Core environment variables",
    nextTitle: "Next improvements",
    statusTitle: "Current status",
    statusText:
      "The bot is running on Zeabur. Core chat, automatic routing, multiple providers, fallback, web search, URL reading, image/voice/file handling, inline actions, settings, memory and admin controls are in place. Gemini Live audio, image generation and reply formatting will continue to improve based on configuration and available quota.",
    repoLabel: "Open GitHub repository",
  },
};

---

<BaseLayout
  title="Telegram AI Bot · Project Xiomn"
  description="Project Xiomn Telegram AI Bot 项目页。"
  active="projects"
  translations={translations}
>
  <section class="hero">
    <p class="kicker" data-i18n="eyebrow">{translations.zh.eyebrow}</p>
    <h1 class="hero-title" data-i18n="title">{translations.zh.title}</h1>
    <p class="lead" data-i18n="intro">{translations.zh.intro}</p>
  </section>

  <section class="section">
    <div class="grid two">
      <article class="panel">
        <p class="kicker" data-i18n="statusTitle">{translations.zh.statusTitle}</p>
        <p data-i18n="statusText">{translations.zh.statusText}</p>
      </article>

      <article class="panel">
        <p class="kicker">REPOSITORY</p>
        <h2 class="section-title">Telegram-AI-Bot-Pro</h2>
        <p>huahua6688/Telegram-AI-Bot-Pro</p>
        <div class="actions" style="margin-top: 18px;">
          <a
            class="btn primary"
            href="https://github.com/huahua6688/Telegram-AI-Bot-Pro"
            target="_blank"
            rel="noreferrer"
            data-i18n="repoLabel"
          >
            {translations.zh.repoLabel}
          </a>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title" data-i18n="featureTitle">{translations.zh.featureTitle}</h2>
    </div>

    <div class="grid two">
      {features.map((item) => (
        <article class="card">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title" data-i18n="envTitle">{translations.zh.envTitle}</h2>
    </div>

    <div class="tags">
      {envs.map((item) => <span>{item}</span>)}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title" data-i18n="nextTitle">{translations.zh.nextTitle}</h2>
    </div>

    <div class="timeline">
      {nextActions.map((item, index) => (
        <div class="timeline-item">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <p>{item}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
