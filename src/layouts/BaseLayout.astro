---
import "../styles/global.css";

const {
  title = "Project Xiomn",
  description = "Project Xiomn",
  active = "home",
  translations = {},
} = Astro.props;

const year = new Date().getFullYear();
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <main class="site-shell">
      <nav class="site-nav">
        <a class="brand" href="/">
          <span class="brand-mark">X</span>
          <span>Project Xiomn</span>
        </a>

        <div class="nav-links">
          <a class={active === "home" ? "active" : ""} href="/" data-i18n="navHome">首页</a>
          <a class={active === "projects" ? "active" : ""} href="/projects" data-i18n="navProjects">项目</a>
          <a class={active === "docs" ? "active" : ""} href="/docs" data-i18n="navDocs">文档</a>
          <a class={active === "status" ? "active" : ""} href="/status" data-i18n="navStatus">状态</a>
          <a class={active === "about" ? "active" : ""} href="/about" data-i18n="navAbout">关于</a>
        </div>

        <label class="language-switcher" aria-label="选择语言">
          <span class="language-icon">🌐</span>
          <select data-language-select>
            <option value="zh">中文</option>
            <option value="en">English</option>
            <option value="ja">日本語</option>
            <option value="km">ខ្មែរ</option>
            <option value="ms">Malay</option>
          </select>
          <span class="language-arrow">⌄</span>
        </label>
      </nav>

      <slot />

      <footer class="footer">
        <span>© {year} Project Xiomn</span>
        <span data-i18n="footer">由 Astro、Nginx、GitHub 构建。</span>
      </footer>
    </main>

    <script define:vars={{ pageCopy: translations }}>
      const languages = ["zh", "en", "ja", "km", "ms"];

      const commonCopy = {
        zh: {
          navHome: "首页",
          navProjects: "项目",
          navDocs: "文档",
          navStatus: "状态",
          navAbout: "关于",
          footer: "由 Astro、Nginx、GitHub 构建。",
        },
        en: {
          navHome: "Home",
          navProjects: "Projects",
          navDocs: "Docs",
          navStatus: "Status",
          navAbout: "About",
          footer: "Built with Astro, Nginx and GitHub.",
        },
        ja: {
          navHome: "ホーム",
          navProjects: "プロジェクト",
          navDocs: "ドキュメント",
          navStatus: "状態",
          navAbout: "概要",
          footer: "Astro、Nginx、GitHub で構築。",
        },
        km: {
          navHome: "ទំព័រដើម",
          navProjects: "គម្រោង",
          navDocs: "ឯកសារ",
          navStatus: "ស្ថានភាព",
          navAbout: "អំពី",
          footer: "បង្កើតដោយ Astro, Nginx និង GitHub។",
        },
        ms: {
          navHome: "Utama",
          navProjects: "Projek",
          navDocs: "Dokumen",
          navStatus: "Status",
          navAbout: "Tentang",
          footer: "Dibina dengan Astro, Nginx dan GitHub.",
        },
      };

      const copy = {};

      languages.forEach((lang) => {
        copy[lang] = {
          ...(commonCopy[lang] || {}),
          ...((pageCopy && pageCopy[lang]) || {}),
        };
      });

      function getInitialLang() {
        const params = new URLSearchParams(window.location.search);
        const urlLang = params.get("lang");

        if (urlLang && copy[urlLang]) {
          localStorage.setItem("xiomn-lang", urlLang);
          return urlLang;
        }

        return localStorage.getItem("xiomn-lang") || "zh";
      }

      function applyLang(lang) {
        const safeLang = copy[lang] ? lang : "zh";
        const dict = copy[safeLang];

        document.documentElement.lang = safeLang === "zh" ? "zh-CN" : safeLang;

        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.getAttribute("data-i18n");

          if (key && dict[key] !== undefined) {
            el.textContent = dict[key];
          }
        });

        const languageSelect = document.querySelector("[data-language-select]");

        if (languageSelect) {
          languageSelect.value = safeLang;
        }

        if (dict.metaTitle) {
          document.title = dict.metaTitle;
        }

        localStorage.setItem("xiomn-lang", safeLang);
      }

      const languageSelect = document.querySelector("[data-language-select]");

      if (languageSelect) {
        languageSelect.addEventListener("change", (event) => {
          applyLang(event.target.value);
        });
      }

      applyLang(getInitialLang());
    </script>
  </body>
</html>
