---
import "../styles/global.css";

const {
  title = "Project Xiomn",
  description = "Project Xiomn",
  active = "home",
  translations = {},
} = Astro.props;

const year = new Date().getFullYear();
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <main class="site-shell">
      <nav class="site-nav">
        <a class="brand" href="/">
          <span class="brand-mark">X</span>
          <span>Project Xiomn</span>
        </a>

        <div class="nav-links">
          <a class={active === "home" ? "active" : ""} href="/" data-i18n="navHome">首页</a>
          <a class={active === "projects" ? "active" : ""} href="/projects" data-i18n="navProjects">项目</a>
          <a class={active === "services" ? "active" : ""} href="/services" data-i18n="navServices">服务</a>
          <a class={active === "docs" ? "active" : ""} href="/docs" data-i18n="navDocs">文档</a>
          <a class={active === "status" ? "active" : ""} href="/status" data-i18n="navStatus">状态</a>
          <a class={active === "about" ? "active" : ""} href="/about" data-i18n="navAbout">关于</a>
          <a href="/system" data-i18n="navSystem">系统</a>
        </div>

        <div class="language-switcher" data-language-menu>
          <button
            class="language-trigger"
            type="button"
            data-language-trigger
            aria-haspopup="listbox"
            aria-expanded="false"
          >
            <span data-current-language>中文</span>
            <span class="chevron">⌄</span>
          </button>

          <div class="language-menu" data-language-list role="listbox" hidden>
            <button type="button" data-lang="zh">中文</button>
            <button type="button" data-lang="en">English</button>
            <button type="button" data-lang="ja">日本語</button>
            <button type="button" data-lang="km">ខ្មែរ</button>
            <button type="button" data-lang="ms">Malay</button>
          </div>
        </div>
      </nav>

      <slot />

      <footer class="footer">
        <span>© {year} Project Xiomn</span>
        <span data-i18n="footer">由 Astro、Zeabur、GitHub 构建。</span>
      </footer>
    </main>

    <script define:vars={{ pageCopy: translations }}>
      const languages = ["zh", "en", "ja", "km", "ms"];

      const languageLabels = {
        zh: "中文",
        en: "English",
        ja: "日本語",
        km: "ខ្មែរ",
        ms: "Malay",
      };

      const commonCopy = {
        zh: {
          navHome: "首页",
          navProjects: "项目",
          navServices: "服务",
          navDocs: "文档",
          navStatus: "状态",
          navAbout: "关于",
          navSystem: "系统",
          footer: "由 Astro、Zeabur、GitHub 构建。",
        },
        en: {
          navHome: "Home",
          navProjects: "Projects",
          navServices: "Services",
          navDocs: "Docs",
          navStatus: "Status",
          navAbout: "About",
          navSystem: "System",
          footer: "Built with Astro, Zeabur and GitHub.",
        },
        ja: {
          navHome: "ホーム",
          navProjects: "プロジェクト",
          navServices: "サービス",
          navDocs: "ドキュメント",
          navStatus: "状態",
          navAbout: "概要",
          navSystem: "システム",
          footer: "Astro、Zeabur、GitHub で構築。",
        },
        km: {
          navHome: "ទំព័រដើម",
          navProjects: "គម្រោង",
          navServices: "សេវាកម្ម",
          navDocs: "ឯកសារ",
          navStatus: "ស្ថានភាព",
          navAbout: "អំពី",
          navSystem: "ប្រព័ន្ធ",
          footer: "បង្កើតដោយ Astro, Zeabur និង GitHub។",
        },
        ms: {
          navHome: "Utama",
          navProjects: "Projek",
          navServices: "Servis",
          navDocs: "Dokumen",
          navStatus: "Status",
          navAbout: "Tentang",
          navSystem: "Sistem",
          footer: "Dibina dengan Astro, Zeabur dan GitHub.",
        },
      };

      const copy = {};

      languages.forEach((lang) => {
        copy[lang] = {
          ...(commonCopy[lang] || {}),
          ...((pageCopy && pageCopy[lang]) || {}),
        };
      });

      function getInitialLang() {
        const params = new URLSearchParams(window.location.search);
        const urlLang = params.get("lang");

        if (urlLang && copy[urlLang]) {
          localStorage.setItem("xiomn-lang", urlLang);
          return urlLang;
        }

        return localStorage.getItem("xiomn-lang") || "zh";
      }

      function closeLanguageMenu() {
        const list = document.querySelector("[data-language-list]");
        const trigger = document.querySelector("[data-language-trigger]");

        if (list) list.hidden = true;
        if (trigger) trigger.setAttribute("aria-expanded", "false");
      }

      function applyLang(lang) {
        const safeLang = copy[lang] ? lang : "zh";
        const dict = copy[safeLang];

        document.documentElement.lang = safeLang === "zh" ? "zh-CN" : safeLang;

        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.getAttribute("data-i18n");

          if (key && dict[key] !== undefined) {
            el.textContent = dict[key];
          }
        });

        const label = document.querySelector("[data-current-language]");
        if (label) label.textContent = languageLabels[safeLang] || "中文";

        document.querySelectorAll("[data-lang]").forEach((btn) => {
          btn.classList.toggle("active", btn.getAttribute("data-lang") === safeLang);
        });

        if (dict.metaTitle) {
          document.title = dict.metaTitle;
        }

        localStorage.setItem("xiomn-lang", safeLang);
      }

      const trigger = document.querySelector("[data-language-trigger]");
      const list = document.querySelector("[data-language-list]");
      const menu = document.querySelector("[data-language-menu]");

      if (trigger && list) {
        trigger.addEventListener("click", () => {
          const willOpen = list.hidden;
          list.hidden = !willOpen;
          trigger.setAttribute("aria-expanded", String(willOpen));
        });
      }

      document.querySelectorAll("[data-lang]").forEach((btn) => {
        btn.addEventListener("click", () => {
          applyLang(btn.getAttribute("data-lang"));
          closeLanguageMenu();
        });
      });

      document.addEventListener("click", (event) => {
        if (menu && !menu.contains(event.target)) {
          closeLanguageMenu();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeLanguageMenu();
        }
      });

      applyLang(getInitialLang());
    </script>
  </body>
</html>
